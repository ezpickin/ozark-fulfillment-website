---
const year = new Date().getFullYear();
---

<footer class="site-footer" id="contact">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="logo-badge footer-logo">
        <img src="/logo.png" alt="Ozark Fulfillment logo" width="64" height="64" />
      </span>
      <div>
        <strong>Ozark Fulfillment</strong>
        <p>Warehousing &amp; Fulfillment in the Missouri Ozarks</p>
      </div>
    </div>

    <address class="footer-contact">
      <p>1475 S Sam Houston Blvd<br />Houston, MO 65483</p>
      <p><a href="tel:+14174531005">(417) 453-1005</a></p>
      <p><a href="mailto:trevor@ozarkfulfillment.com">trevor@ozarkfulfillment.com</a></p>
      <p class="footer-hours">Mon–Fri, 8:00 AM – 4:30 PM CT</p>
    </address>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="#services">Services</a>
      <a href="#why-us">Why Us</a>
      <a href="#about">About</a>
      <a href="#quote">Get a Quote</a>
    </nav>
  </div>
  <div class="container footer-bottom">
    <p>© {year} Ozark Fulfillment. All rights reserved.</p>
    <a href="/privacy" class="footer-privacy">Privacy Policy</a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-900);
    color: #cfdce8;
    padding: 3.5rem 0 1.5rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-brand {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-logo {
    width: 64px;
    height: 64px;
  }

  .footer-brand strong {
    color: #fff;
    font-size: 1.05rem;
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: var(--sky);
  }

  .footer-contact {
    font-style: normal;
    display: grid;
    gap: 0.5rem;
    font-size: 0.95rem;
  }

  .footer-contact a {
    color: var(--sky);
    text-decoration: none;
  }

  .footer-contact a:hover {
    text-decoration: underline;
  }

  .footer-hours {
    color: #cfdce8;
  }

  .footer-nav {
    display: grid;
    gap: 0.5rem;
    align-content: start;
  }

  .footer-nav a {
    color: #cfdce8;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .footer-nav a:hover {
    color: var(--sky);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    font-size: 0.85rem;
    color: #8fa5b8;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .footer-privacy {
    color: #8fa5b8;
    text-decoration: none;
  }

  .footer-privacy:hover {
    color: var(--sky);
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
