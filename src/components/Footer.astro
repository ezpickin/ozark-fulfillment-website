---
const year = new Date().getFullYear();
---

<footer class="site-footer" id="contact">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="logo-badge footer-logo">
        <img src="/logo.png" alt="Ozark Fulfillment logo" width="64" height="64" />
      </span>
      <div>
        <strong>Ozark Fulfillment</strong>
        <p>Warehousing &amp; Fulfillment in the Missouri Ozarks</p>
        <div class="footer-social">
          <a
            href="https://www.linkedin.com/company/ozark-fulfillment/"
            target="_blank"
            rel="noopener"
            aria-label="Ozark Fulfillment on LinkedIn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.75-2.05C20.3 8.65 21 11 21 14.1V21h-4v-6.1c0-1.45-.03-3.3-2-3.3-2 0-2.3 1.57-2.3 3.2V21H9z" />
            </svg>
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=61589692852709"
            target="_blank"
            rel="noopener"
            aria-label="Ozark Fulfillment on Facebook"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <address class="footer-contact">
      <p>1475 S Sam Houston Blvd<br />Houston, MO 65483</p>
      <p><a href="tel:+14174531005">(417) 453-1005</a></p>
      <p><a href="mailto:trevor@ozarkfulfillment.com">trevor@ozarkfulfillment.com</a></p>
      <p class="footer-hours">Mon–Fri, 8:00 AM – 4:30 PM CT</p>
    </address>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="#services">Services</a>
      <a href="#why-us">Why Us</a>
      <a href="#about">About</a>
      <a href="#quote">Get a Quote</a>
    </nav>
  </div>
  <div class="container footer-bottom">
    <p>© {year} Ozark Fulfillment. All rights reserved.</p>
    <a href="/privacy" class="footer-privacy">Privacy Policy</a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-900);
    color: #cfdce8;
    padding: 3.5rem 0 1.5rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1.5fr 1fr;
    gap: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .footer-brand {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-logo {
    width: 64px;
    height: 64px;
  }

  .footer-brand strong {
    color: #fff;
    font-size: 1.05rem;
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: var(--sky);
  }

  .footer-social {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.75rem;
  }

  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: #cfdce8;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .footer-social a:hover {
    background: var(--sky);
    color: var(--navy-900);
  }

  .footer-social svg {
    width: 20px;
    height: 20px;
  }

  .footer-contact {
    font-style: normal;
    display: grid;
    gap: 0.5rem;
    font-size: 0.95rem;
  }

  .footer-contact a {
    color: var(--sky);
    text-decoration: none;
  }

  .footer-contact a:hover {
    text-decoration: underline;
  }

  .footer-hours {
    color: #cfdce8;
  }

  .footer-nav {
    display: grid;
    gap: 0.5rem;
    align-content: start;
  }

  .footer-nav a {
    color: #cfdce8;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .footer-nav a:hover {
    color: var(--sky);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    font-size: 0.85rem;
    color: #8fa5b8;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .footer-privacy {
    color: #8fa5b8;
    text-decoration: none;
  }

  .footer-privacy:hover {
    color: var(--sky);
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
