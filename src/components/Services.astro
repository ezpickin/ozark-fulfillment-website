---
const services = [
  {
    // truck
    svg: '<rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>',
    title: 'Receiving & Shipping',
    body: 'LTL, full truckload (FTL), floor-loaded containers (20′ and 40′), and carton forwarding — unloaded, counted, and put away within 48 hours, with any discrepancies reported to you same day.',
  },
  {
    // warehouse
    svg: '<path d="M3 21V7l9-4 9 4v14"/><path d="M3 11h18"/><path d="M3 16h18"/><path d="M9 21v-5h6v5"/>',
    title: 'Storage',
    body: 'Clean, organized storage — including climate-controlled space — with real-time inventory visibility. Pay only for the space you actually use.',
  },
  {
    // package
    svg: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
    title: 'DTC Fulfillment',
    body: 'Fast, accurate pick, pack, and ship for your Shopify, TikTok Shop, and marketplace orders — same-day shipping on orders received by our 12:00 PM CT cutoff.',
  },
  {
    // tag / label
    svg: '<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>',
    title: 'Marketplace & FBA Prep',
    body: 'SKU labeling (individual or bulk), polybagging, bundling, and case prep to Amazon and Walmart spec, so your shipments check in without issues. Normal turnaround time is 24–48 hours.',
  },
  {
    // tool / wrench
    svg: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
    title: 'Value-Added Services',
    body: 'Kitting, assortments, bubble wrap, repacking, and custom projects. If it needs hands-on work before it ships, we handle it — priced transparently.',
  },
];
---

<section class="services" id="services">
  <div class="container">
    <h2 class="section-title">Everything between your supplier and your customer</h2>
    <p class="section-lede">
      One warehouse, one point of contact, every service your inventory needs.
    </p>
    <div class="grid">
      {
        services.map((s) => (
          <article class="card">
            <div class="icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={s.svg}
              />
            </div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </article>
        ))
      }
      <article class="card card-cta">
        <h3>Something else?</h3>
        <p>
          Odd-sized freight, returns processing, special projects — ask us. If we can do it
          well, we'll quote it.
        </p>
        <a href="#quote" class="btn btn-primary">Ask About Your Project</a>
      </article>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--bg);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--bg-alt);
    border: 1px solid #e2ebf2;
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: rgba(58, 125, 58, 0.1);
    color: var(--green);
    margin-bottom: 1rem;
  }

  .icon svg {
    width: 28px;
    height: 28px;
  }

  .card h3 {
    color: var(--navy-800);
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .card p {
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .card-cta {
    background: var(--navy-800);
    border-color: var(--navy-700);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .card-cta h3 {
    color: #fff;
  }

  .card-cta p {
    color: #d4e2ee;
  }

  .card-cta .btn {
    margin-top: auto;
  }
</style>
